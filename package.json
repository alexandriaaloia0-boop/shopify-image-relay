{
  "name": "shopify-image-relay",
  "version": "1.0.0",
  "description": "A minimal image relay for Shopify, n8n, and Wasabi S3 storage.",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test tests/*.test.ts"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.887.0",
    "fastify": "^5.6.0",
    "file-type": "^21.0.0",
    "ipaddr.js": "^2.2.0",
    "sharp": "^0.34.4"
  },
  "devDependencies": {
    "@types/node": "^24.3.1",
    "tsx": "^4.20.5",
    "typescript": "^5.9.2"
  }
}
